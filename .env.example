# Wayfinder environment variables.
# Copy to .env.local and fill in. Every one of these is OPTIONAL — with none set,
# the app runs in local (device-only) mode and never makes network calls.

# ── Backend: accounts + shared venues (Supabase) ─────────────────────────────
# Project Settings → API in your Supabase dashboard. The anon key is meant to be
# public; access is governed by Row-Level Security, not by hiding the key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI sign-reading in Survey Mode (server-side only) ────────────────────────
ANTHROPIC_API_KEY=

# ── Real outdoor routing + place search (server-side only) ───────────────────
MAPBOX_ACCESS_TOKEN=
