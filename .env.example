# Wayfinder environment variables.
# Copy to .env.local and fill in. Every one of these is OPTIONAL — with none set,
# the app runs in local (device-only) mode and never makes network calls.

# ── Backend: pooled navigation signals + search misses (Railway Postgres) ────
# Railway's Postgres plugin sets this automatically when the database is attached
# to the service. Use the private URL (…​.railway.internal) when the app runs on
# Railway; the public URL (with ?sslmode=require) when it runs elsewhere.
DATABASE_URL=

# ── AI sign-reading in Survey Mode (server-side only) ────────────────────────
ANTHROPIC_API_KEY=

# ── Real outdoor routing + place search (server-side only) ───────────────────
MAPBOX_ACCESS_TOKEN=
