# Wayfinder environment variables.
# Copy to .env.local and fill in. Every one of these is OPTIONAL — with none set,
# the app runs in local (device-only) mode and never makes network calls.

# ── Backend: pooled navigation signals + search misses + shared venues (Railway Postgres) ──
# Railway's Postgres plugin exposes two connection strings. The app reads either.
#   • On Railway: DATABASE_URL (the private …​.railway.internal host).
#   • On Vercel (or anywhere reaching Railway over the internet): DATABASE_PUBLIC_URL.
# Set whichever matches where the app runs. TLS is turned on automatically for a
# remote host, so ?sslmode=require is not required in the string.
DATABASE_URL=
DATABASE_PUBLIC_URL=

# ── AI sign-reading in Survey Mode (server-side only) ────────────────────────
ANTHROPIC_API_KEY=

# ── Real outdoor routing + place search (server-side only) ───────────────────
MAPBOX_ACCESS_TOKEN=

# ── Optional accounts (Clerk) ────────────────────────────────────────────────
# Sign-in is deliberately optional and additive. Wayfinder works fully
# anonymously — you never have to sign in to find a ward, the same way Google
# Maps and Apple Maps let you navigate signed out. An account only carries the
# things that must follow a *person* rather than a device: saved places, and
# ownership of a venue you mapped.
#
# With these unset, ClerkProvider is not mounted (src/app/layout.tsx) and
# src/proxy.ts is a pass-through, so the app behaves exactly as it always has.
#
# Note src/proxy.ts deliberately EXCLUDES /navigate from the auth matcher: that
# is the route used inside hospitals where signal dies, and it must never depend
# on an auth round-trip.
#
# Keys: https://dashboard.clerk.com/ → your app → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
